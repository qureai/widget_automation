{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020", "dom"],
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "baseUrl": ".",
    "paths": {
      "@steps/*": ["steps/*"],
      "@src/*": ["src/*"],
      "@features/*": ["features/*"]
    }
  },
  "include": ["features/**/*.ts", "steps/**/*.ts", "src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
